---
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	slug: string;
}

const { title, description, pubDate, slug } = Astro.props;
---

<article class="post-card">
	<a href={`/blog/${slug}/`}>
		<div class="post-meta">
			<FormattedDate date={pubDate} />
		</div>
		<h3 class="post-title">{title}</h3>
		<p class="post-description">{description}</p>
	</a>
</article>
<style>
	.post-card {
		padding: 1.5em 0;
		border-bottom: 1px solid var(--border);
	}
	.post-card:last-child {
		border-bottom: none;
	}
	.post-card a {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	.post-card a:hover .post-title {
		color: var(--accent);
	}
	.post-meta {
		color: var(--text-secondary);
		font-size: 0.875em;
		margin-bottom: 0.25em;
	}
	.post-title {
		margin: 0 0 0.5em 0;
		font-size: 1.25em;
		line-height: 1.3;
		transition: color 0.15s ease;
	}
	.post-description {
		color: var(--text-secondary);
		margin: 0;
		font-size: 0.95em;
		line-height: 1.5;
	}
</style>
