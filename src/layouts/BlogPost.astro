---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;

// Estimate reading time
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				max-width: 680px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.post-header {
				margin-bottom: 2em;
			}
			.post-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.2;
			}
			.post-meta {
				color: var(--text-secondary);
				font-size: 0.9em;
			}
			.post-meta .updated {
				font-style: italic;
			}
			.prose :global(h2) {
				margin-top: 2em;
			}
			.prose :global(h3) {
				margin-top: 1.5em;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1.5em;
				color: var(--text-secondary);
				font-size: 0.9em;
			}
			.back-link:hover {
				color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="prose">
				<a href="/blog" class="back-link">&larr; All posts</a>
				<div class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									&mdash; Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
				</div>
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
